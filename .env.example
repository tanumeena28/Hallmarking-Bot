# Database — local PostgreSQL on Windows
DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/nch_audit

# JWT
JWT_SECRET=your-secret-key-change-this

# LLM — use groq for now
LLM_PROVIDER=groq
GROQ_API_KEY=your-groq-api-key

# Metals API for gold rate
METALS_API_KEY=your-metals-api-key

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME="Hallmarking Bot"

# Text-to-Speech (TTS) Config
# Choose from: auto (default, auto-detects keys), gtts (free), google (Google Cloud), bhashini (Govt of India Bhashini)
TTS_PROVIDER=auto

# Google Cloud TTS credentials (Optional, for premium Neural2 Indian voices)
# GOOGLE_API_KEY=your_google_cloud_api_key

# Bhashini TTS credentials (Optional, for premium Indian regional voices)
# BHASHINI_API_KEY=your_bhashini_api_key
# BHASHINI_USER_ID=your_bhashini_user_id
# BHASHINI_INFERENCE_URL=https://meity-auth.ulcacognitive.org/v1/pipeline/compute
# BHASHINI_VOICE_GENDER=female

# CORS Settings for Production (comma-separated list, e.g., https://admin.hallmarkingbot.com,http://localhost:5173)
# ALLOWED_ORIGINS=*


